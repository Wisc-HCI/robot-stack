AMENT_PREFIX_PATH=/opt/ros/jazzy
CMAKE_PREFIX_PATH=/opt/ros/jazzy/opt/gz_math_vendor:/opt/ros/jazzy/opt/gz_utils_vendor:/opt/ros/jazzy/opt/gz_cmake_vendor:/opt/openrobots:
COLCON=1
DEBIAN_FRONTEND=noninteractive
DISPLAY=:1
HOME=/root
HOSTNAME=pop-os
LANG=C.UTF-8
LC_ALL=C.UTF-8
LD_LIBRARY_PATH=/opt/ros/jazzy/opt/rviz_ogre_vendor/lib:/opt/ros/jazzy/lib/x86_64-linux-gnu:/opt/ros/jazzy/opt/gz_math_vendor/lib:/opt/ros/jazzy/opt/gz_utils_vendor/lib:/opt/ros/jazzy/opt/gz_cmake_vendor/lib:/opt/ros/jazzy/lib:/opt/openrobots/lib:
OLDPWD=/workspace
PATH=/opt/ros/jazzy/bin:/root/.cargo/bin:/opt/openrobots/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PIP_BREAK_SYSTEM_PACKAGES=1
PKG_CONFIG_PATH=/opt/openrobots/lib/pkgconfig:
PWD=/workspace/libs/robot_motion_interface/ros/build/robot_motion_interface_ros_msgs
PYTHONPATH=/opt/ros/jazzy/lib/python3.12/site-packages:/opt/openrobots/lib/python3.10/site-packages:
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
ROS_DISTRO=jazzy
ROS_PYTHON_VERSION=3
ROS_STATIC_PEERS=192.168.4.9
ROS_VERSION=2
SHLVL=1
TERM=xterm
_=/usr/bin/colcon
